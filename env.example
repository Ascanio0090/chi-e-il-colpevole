# Copia questo file in .env e inserisci la tua API key GRATUITA di Groq
# 1. Vai su https://console.groq.com
# 2. Registrati (gratis)
# 3. Vai su API Keys -> Create API Key
# 4. Incolla la chiave qui sotto

GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Porta del server (opzionale, default 3000)
PORT=3000
